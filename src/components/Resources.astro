---
const links = [
  { name: 'ՀՀ իրավական տեղեկատվական համակարգ', url: 'https://www.laws.am', desc: 'laws.am' },
  { name: 'ՀՀ հաշվապահների և աուդիտորների ասոցիացիա', url: 'https://www.aaaa.am', desc: 'aaaa.am' },
  { name: 'Հաշվապահների միջազգային դաշնություն (IFAC)', url: 'https://www.ifac.org', desc: 'ifac.org' },
  { name: 'ՀՀ ֆինանսների նախարարություն', url: 'https://www.mfe.am', desc: 'mfe.am' },
  { name: 'ՀՀ Ազգային ժողով', url: 'https://www.parliament.am', desc: 'parliament.am' },
  { name: 'ՀՀ կառավարություն', url: 'https://www.gov.am', desc: 'gov.am' },
  { name: 'ՀՀ կենտրոնական բանկ', url: 'https://www.cba.am', desc: 'cba.am' },
  { name: 'ՀՀ պետական եկամուտների կոմիտե', url: 'https://www.taxservice.am', desc: 'taxservice.am' },
];
---

<section id="resources" class="py-16 lg:py-24 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <span class="text-gold-500 font-semibold text-sm tracking-wider uppercase">Հղումներ</span>
      <h2 class="font-heading text-4xl lg:text-5xl text-burgundy-900 mt-4 gold-line-center">
        Օգտակար Հղումներ
      </h2>
      <p class="text-charcoal/60 mt-8 max-w-2xl mx-auto">
        Կարևոր պետական և միջազգային կայքերի հղումներ
      </p>
    </div>

    <div class="reveal reveal-stagger grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {links.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener"
          class="group bg-white rounded-xl p-6 border border-stone/50 hover:border-burgundy-200 hover:shadow-md transition-all duration-300"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-burgundy-50 rounded-lg flex items-center justify-center group-hover:bg-burgundy-100 transition-colors">
              <svg class="w-5 h-5 text-burgundy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </div>
            <span class="text-xs text-gold-600 font-medium">{link.desc}</span>
          </div>
          <p class="text-sm text-charcoal/80 font-medium group-hover:text-burgundy-900 transition-colors leading-relaxed">{link.name}</p>
        </a>
      ))}
    </div>
  </div>
</section>
