---
---

<section id="contact" class="py-24 lg:py-32 bg-cream">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <span class="text-gold-500 font-semibold text-sm tracking-wider uppercase">Կապ</span>
      <h2 class="font-heading text-4xl lg:text-5xl text-burgundy-900 mt-4 gold-line-center">
        Դիմեք Մեզ
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <div class="reveal">
        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-burgundy-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-burgundy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Հասցե</h3>
              <p class="text-charcoal/60">ՀՀ, ք. Երևան, Կոմիտաս, 54/բ</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-burgundy-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-burgundy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Հեռախոս</h3>
              <a href="tel:+37410235653" class="block text-charcoal/60 hover:text-burgundy-900 transition-colors">+374 10 235 653</a>
              <a href="tel:+37477676716" class="block text-charcoal/60 hover:text-burgundy-900 transition-colors">077-67-67-16</a>
              <a href="tel:+37499278158" class="block text-charcoal/60 hover:text-burgundy-900 transition-colors">099-27-81-58</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-burgundy-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-burgundy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Էլ. հասցե</h3>
              <a href="mailto:bacaccounting@yandex.com" class="text-burgundy-900 hover:text-gold-500 transition-colors">bacaccounting@yandex.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-burgundy-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-burgundy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-charcoal mb-1">Աշխատանքային ժամեր</h3>
              <p class="text-charcoal/60">Երկուշաբթի - Ուրբաթ՝ 09:00 - 19:00</p>
            </div>
          </div>
        </div>

        <div class="mt-10 rounded-2xl overflow-hidden shadow-lg border border-stone/50 h-64">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3047.5!2d44.516079!3d40.20509!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDEyJzE4LjMiTiA0NMKwMzAnNTcuOSJF!5e0!3m2!1shy!2sam!4v1"
            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <div class="reveal">
        <form class="bg-white rounded-2xl p-8 lg:p-10 shadow-sm border border-stone/50">
          <h3 class="font-heading text-2xl text-burgundy-900 mb-6">Գրեք մեզ</h3>
          <div class="space-y-5">
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Անուն, Ազգանուն</label>
              <input type="text" name="name" required class="w-full px-4 py-3 rounded-xl border border-stone bg-cream focus:outline-none focus:ring-2 focus:ring-burgundy-900/20 focus:border-burgundy-900 transition-all" />
            </div>
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Էլ. հասցե</label>
              <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-stone bg-cream focus:outline-none focus:ring-2 focus:ring-burgundy-900/20 focus:border-burgundy-900 transition-all" />
            </div>
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Հեռախոս</label>
              <input type="tel" name="phone" class="w-full px-4 py-3 rounded-xl border border-stone bg-cream focus:outline-none focus:ring-2 focus:ring-burgundy-900/20 focus:border-burgundy-900 transition-all" placeholder="+374 XX XXX XXX" />
            </div>
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Ծառայություն</label>
              <select name="service" class="w-full px-4 py-3 rounded-xl border border-stone bg-cream focus:outline-none focus:ring-2 focus:ring-burgundy-900/20 focus:border-burgundy-900 transition-all">
                <option value="">Ընտրեք ծառայությունը...</option>
                <option>Հաշվապահության վարում</option>
                <option>Բիզնեսի գրանցում</option>
                <option>Ծրագրերի վաճառք</option>
                <option>Հաշվապահության ուսուցում</option>
                <option>1C ծրագրի ուսուցում</option>
                <option>MS Office դասընթաց</option>
                <option>Այլ</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-charcoal mb-2">Հաղորդագրություն</label>
              <textarea name="message" rows="4" class="w-full px-4 py-3 rounded-xl border border-stone bg-cream focus:outline-none focus:ring-2 focus:ring-burgundy-900/20 focus:border-burgundy-900 transition-all resize-none"></textarea>
            </div>
            <button type="submit" class="w-full py-4 bg-burgundy-900 text-white font-semibold rounded-xl hover:bg-burgundy-950 transition-colors duration-200 shadow-lg shadow-burgundy-900/25">
              Ուղարկել
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
